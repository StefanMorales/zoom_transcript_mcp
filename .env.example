# Zoom API Credentials
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Email of the Zoom user whose AI Companion transcripts should be fetched
# (used for the /report/users/{email}/meetings lookup — not a secret, just an identifier)
ZOOM_USER_EMAIL=you@example.com

# Optional: Custom transcripts directory (defaults to ./transcripts)
# TRANSCRIPTS_DIR=/path/to/transcripts/directory

# Optional, used only by route_transcripts.mjs: where your domain folders (Clients/,
# Collaborators/, etc. — or whatever categories you use) live, and where your hints file is.
# Defaults to one level up from this repo, and to ./hints.json, if unset. See hints.example.json.
# ROUTING_WORKSPACE_DIR=/path/to/your/workspace
# ROUTING_HINTS_FILE=/path/to/your/hints.json

# Optional: sorting-hat notifications when route_transcripts.mjs finds anything ambiguous
# or unmatched. Create a bot via @BotFather on Telegram, message it once, then get your
# chat ID from https://api.telegram.org/bot<token>/getUpdates. Leave both blank to skip.
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
