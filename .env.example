# Zoom API Credentials
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Email of the Zoom user whose AI Companion transcripts should be fetched
# (used for the /report/users/{email}/meetings lookup — not a secret, just an identifier)
ZOOM_USER_EMAIL=you@example.com

# Optional: Custom transcripts directory (defaults to ./transcripts)
# TRANSCRIPTS_DIR=/path/to/transcripts/directory
